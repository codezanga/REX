<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>REX REALTYCO — Property Database</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Josefin+Sans:wght@300;400;600&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C8960C;
    --gold-light: #E8B830;
    --dark: #0F0A04;
    --dark-2: #1A1208;
    --dark-3: #241A0A;
    --dark-4: #2E2210;
    --cream: #F5EFE0;
    --text: #E8DEC8;
    --text-dim: #6A5830;
    --text-muted: #3A2E18;
    --sale: #4CAF7D;
    --rent: #4A9EBF;
    --sold: #BF6A4A;
    --offer: #9B7FCF;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--dark);
    color: var(--text);
    font-family: 'Josefin Sans', sans-serif;
    min-height: 100vh;
  }

  header {
    background: var(--dark-2);
    border-bottom: 1px solid var(--dark-4);
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo-area { display: flex; align-items: center; gap: 14px; }

  .logo-text { display: flex; flex-direction: column; }
  .logo-text span:first-child {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; font-weight: 700;
    color: var(--gold); letter-spacing: 3px; line-height: 1;
  }
  .logo-text span:last-child {
    font-size: 8px; letter-spacing: 4px;
    color: var(--text-dim); text-transform: uppercase; margin-top: 2px;
  }

  .header-right { display: flex; align-items: center; gap: 12px; }

  .stat-pill {
    display: flex; align-items: center; gap: 8px;
    background: var(--dark-3); border: 1px solid var(--dark-4);
    border-radius: 20px; padding: 6px 14px;
    font-size: 11px; letter-spacing: 1px; color: var(--text-dim);
  }
  .stat-pill strong {
    color: var(--gold);
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px; font-weight: 600;
  }

  .sync-status {
    display: flex; align-items: center; gap: 6px;
    font-size: 10px; letter-spacing: 2px;
    color: var(--text-muted); text-transform: uppercase;
  }

  .sync-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--sale); animation: pulse 2s infinite;
  }

  .sync-dot.syncing { background: var(--gold); animation: spin 1s linear infinite; border-radius: 0; }
  .sync-dot.error { background: var(--sold); animation: none; }

  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  @keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

  main { padding: 32px; max-width: 1400px; margin: 0 auto; }

  .top-bar {
    display: flex; align-items: center;
    justify-content: space-between;
    margin-bottom: 28px; flex-wrap: wrap; gap: 16px;
  }

  .page-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px; font-weight: 600;
    color: var(--cream); letter-spacing: 1px;
  }
  .page-title span { color: var(--gold); }

  .btn-add {
    display: flex; align-items: center; gap: 8px;
    background: var(--gold); color: var(--dark);
    border: none; padding: 12px 24px; border-radius: 4px;
    font-family: 'Josefin Sans', sans-serif;
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    cursor: pointer; font-weight: 600;
    transition: background 0.2s, transform 0.2s;
  }
  .btn-add:hover { background: var(--gold-light); transform: translateY(-1px); }

  .stats-grid {
    display: grid; grid-template-columns: repeat(4,1fr);
    gap: 16px; margin-bottom: 28px;
  }
  @media(max-width:900px){ .stats-grid{grid-template-columns:repeat(2,1fr);} }

  .stat-card {
    background: var(--dark-2); border: 1px solid var(--dark-4);
    border-radius: 6px; padding: 20px 24px;
    position: relative; overflow: hidden;
    animation: fadeUp 0.5s ease both;
  }
  .stat-card::before {
    content:''; position:absolute;
    top:0;left:0;right:0;height:2px;
  }
  .stat-card:nth-child(1)::before{background:var(--gold);}
  .stat-card:nth-child(2)::before{background:var(--sale);}
  .stat-card:nth-child(3)::before{background:var(--rent);}
  .stat-card:nth-child(4)::before{background:var(--sold);}

  .stat-card-label {
    font-size:9px;letter-spacing:4px;
    text-transform:uppercase;color:var(--text-muted);margin-bottom:10px;
  }
  .stat-card-value {
    font-family:'Cormorant Garamond',serif;
    font-size:42px;font-weight:600;color:var(--cream);line-height:1;
  }
  .stat-card:nth-child(1) .stat-card-value{color:var(--gold);}
  .stat-card:nth-child(2) .stat-card-value{color:var(--sale);}
  .stat-card:nth-child(3) .stat-card-value{color:var(--rent);}
  .stat-card:nth-child(4) .stat-card-value{color:var(--sold);}

  .filters {
    display:flex;gap:10px;margin-bottom:24px;
    flex-wrap:wrap;align-items:center;
  }

  .search-box {
    flex:1;min-width:200px;max-width:320px;
    background:var(--dark-2);border:1px solid var(--dark-4);
    border-radius:4px;padding:10px 16px;
    color:var(--text);font-family:'Josefin Sans',sans-serif;
    font-size:12px;letter-spacing:1px;outline:none;
    transition:border-color 0.2s;
  }
  .search-box::placeholder{color:var(--text-muted);}
  .search-box:focus{border-color:var(--gold);}

  .filter-btn {
    background:var(--dark-2);border:1px solid var(--dark-4);
    color:var(--text-dim);padding:10px 16px;border-radius:4px;
    font-family:'Josefin Sans',sans-serif;font-size:10px;
    letter-spacing:2px;text-transform:uppercase;cursor:pointer;
    transition:all 0.2s;
  }
  .filter-btn:hover,.filter-btn.active{border-color:var(--gold);color:var(--gold);background:rgba(200,150,12,0.08);}

  .filter-select {
    background:var(--dark-2);border:1px solid var(--dark-4);
    color:var(--text-dim);padding:10px 16px;border-radius:4px;
    font-family:'Josefin Sans',sans-serif;font-size:10px;
    letter-spacing:2px;text-transform:uppercase;cursor:pointer;outline:none;
    transition:border-color 0.2s;
  }
  .filter-select:focus{border-color:var(--gold);}
  .filter-select option{background:var(--dark-2);}

  .table-wrap {
    background:var(--dark-2);border:1px solid var(--dark-4);
    border-radius:6px;overflow:hidden;
  }

  table{width:100%;border-collapse:collapse;}

  thead tr{background:var(--dark-3);border-bottom:1px solid var(--dark-4);}

  th {
    font-size:9px;letter-spacing:4px;text-transform:uppercase;
    color:var(--text-muted);padding:16px 20px;text-align:left;
    font-weight:400;white-space:nowrap;
  }

  tbody tr {
    border-bottom:1px solid rgba(58,46,24,0.4);
    transition:background 0.2s;animation:fadeUp 0.4s ease both;
  }
  tbody tr:hover{background:rgba(200,150,12,0.04);}
  tbody tr:last-child{border-bottom:none;}

  td{
    padding:16px 20px;font-size:12px;
    color:var(--text);letter-spacing:0.5px;vertical-align:middle;
  }

  .prop-name{
    font-family:'Lora',serif;font-size:14px;
    color:var(--cream);font-weight:600;margin-bottom:3px;
  }
  .prop-location{font-size:10px;color:var(--text-muted);letter-spacing:1px;}

  .badge{
    display:inline-block;padding:4px 10px;border-radius:20px;
    font-size:9px;letter-spacing:2px;text-transform:uppercase;
    font-weight:600;white-space:nowrap;
  }
  .badge-sale{background:rgba(76,175,125,0.15);color:var(--sale);border:1px solid rgba(76,175,125,0.3);}
  .badge-rent{background:rgba(74,158,191,0.15);color:var(--rent);border:1px solid rgba(74,158,191,0.3);}
  .badge-sold{background:rgba(191,106,74,0.15);color:var(--sold);border:1px solid rgba(191,106,74,0.3);}
  .badge-offer{background:rgba(155,127,207,0.15);color:var(--offer);border:1px solid rgba(155,127,207,0.3);}

  .type-badge{
    display:inline-block;padding:3px 8px;border-radius:3px;
    font-size:9px;letter-spacing:2px;text-transform:uppercase;
  }
  .type-residential{background:rgba(200,150,12,0.1);color:var(--gold);}
  .type-commercial{background:rgba(74,158,191,0.1);color:var(--rent);}
  .type-land{background:rgba(76,175,125,0.1);color:var(--sale);}
  .type-shortlet{background:rgba(207,127,155,0.1);color:#CF7F9B;}

  .price{
    font-family:'Cormorant Garamond',serif;
    font-size:16px;font-weight:600;color:var(--gold);white-space:nowrap;
  }
  .price-sub{font-size:9px;color:var(--text-muted);letter-spacing:1px;}

  .agent-name{font-size:11px;color:var(--text-dim);letter-spacing:1px;}
  .date{font-size:10px;color:var(--text-muted);letter-spacing:1px;}

  .actions{display:flex;gap:8px;}

  .btn-action{
    background:var(--dark-3);border:1px solid var(--dark-4);
    color:var(--text-dim);padding:6px 12px;border-radius:3px;
    font-size:9px;letter-spacing:2px;text-transform:uppercase;
    cursor:pointer;transition:all 0.2s;font-family:'Josefin Sans',sans-serif;
  }
  .btn-action:hover{border-color:var(--gold);color:var(--gold);}
  .btn-action.btn-delete:hover{border-color:var(--sold);color:var(--sold);}

  /* Loading */
  .loading-row td {
    text-align:center;padding:60px;
    color:var(--text-muted);font-size:11px;
    letter-spacing:4px;text-transform:uppercase;
  }

  .loader {
    display:inline-block;width:20px;height:20px;
    border:2px solid var(--dark-4);
    border-top-color:var(--gold);border-radius:50%;
    animation:spin 0.8s linear infinite;margin-right:10px;
    vertical-align:middle;
  }

  .no-results{
    text-align:center;padding:48px;
    color:var(--text-muted);font-size:11px;
    letter-spacing:3px;text-transform:uppercase;
  }

  /* Toast */
  .toast {
    position:fixed;bottom:32px;right:32px;
    background:var(--dark-3);border:1px solid var(--dark-4);
    color:var(--text);padding:14px 24px;border-radius:4px;
    font-size:11px;letter-spacing:2px;text-transform:uppercase;
    z-index:999;transform:translateY(20px);opacity:0;
    transition:all 0.3s;pointer-events:none;
  }
  .toast.show{transform:translateY(0);opacity:1;}
  .toast.success{border-color:var(--sale);color:var(--sale);}
  .toast.error{border-color:var(--sold);color:var(--sold);}

  /* Modal */
  .modal-overlay{
    display:none;position:fixed;inset:0;
    background:rgba(0,0,0,0.85);z-index:200;
    align-items:center;justify-content:center;
    padding:20px;backdrop-filter:blur(4px);
  }
  .modal-overlay.open{display:flex;}

  .modal{
    background:var(--dark-2);border:1px solid var(--dark-4);
    border-radius:8px;width:100%;max-width:600px;
    max-height:90vh;overflow-y:auto;
    animation:modalIn 0.3s ease;
  }

  @keyframes modalIn{
    from{opacity:0;transform:translateY(20px) scale(0.97);}
    to{opacity:1;transform:translateY(0) scale(1);}
  }

  .modal-header{
    padding:28px 32px 20px;border-bottom:1px solid var(--dark-4);
    display:flex;align-items:center;justify-content:space-between;
  }
  .modal-title{
    font-family:'Cormorant Garamond',serif;
    font-size:22px;font-weight:600;color:var(--cream);
  }
  .modal-close{
    background:none;border:1px solid var(--dark-4);
    color:var(--text-muted);width:32px;height:32px;
    border-radius:50%;cursor:pointer;font-size:16px;
    display:flex;align-items:center;justify-content:center;
    transition:all 0.2s;
  }
  .modal-close:hover{border-color:var(--sold);color:var(--sold);}

  .modal-body{padding:28px 32px;}

  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
  .form-group{display:flex;flex-direction:column;gap:8px;}
  .form-group.full{grid-column:1/-1;}

  label{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--text-muted);}

  input,select,textarea{
    background:var(--dark-3);border:1px solid var(--dark-4);
    color:var(--text);padding:12px 14px;border-radius:4px;
    font-family:'Josefin Sans',sans-serif;font-size:12px;
    letter-spacing:1px;outline:none;transition:border-color 0.2s;width:100%;
  }
  input:focus,select:focus,textarea:focus{border-color:var(--gold);}
  input::placeholder,textarea::placeholder{color:var(--text-muted);}
  select option{background:var(--dark-2);}
  textarea{resize:vertical;min-height:80px;}

  .modal-footer{
    padding:20px 32px 28px;
    display:flex;gap:12px;justify-content:flex-end;
  }

  .btn-cancel{
    background:none;border:1px solid var(--dark-4);
    color:var(--text-muted);padding:12px 24px;border-radius:4px;
    font-family:'Josefin Sans',sans-serif;font-size:10px;
    letter-spacing:3px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;
  }
  .btn-cancel:hover{border-color:var(--text-muted);color:var(--text);}

  .btn-save{
    background:var(--gold);border:none;color:var(--dark);
    padding:12px 28px;border-radius:4px;
    font-family:'Josefin Sans',sans-serif;font-size:10px;
    letter-spacing:3px;text-transform:uppercase;cursor:pointer;
    font-weight:600;transition:all 0.2s;
  }
  .btn-save:hover{background:var(--gold-light);}
  .btn-save:disabled{opacity:0.5;cursor:not-allowed;}

  .detail-row{
    display:flex;justify-content:space-between;
    padding:12px 0;border-bottom:1px solid var(--dark-4);font-size:12px;
  }
  .detail-row:last-child{border-bottom:none;}
  .detail-label{color:var(--text-muted);letter-spacing:2px;font-size:10px;text-transform:uppercase;}
  .detail-value{color:var(--cream);text-align:right;}

  @keyframes fadeUp{
    from{opacity:0;transform:translateY(10px);}
    to{opacity:1;transform:translateY(0);}
  }

  @media(max-width:768px){
    main{padding:16px;}header{padding:0 16px;}
    .stats-grid{grid-template-columns:repeat(2,1fr);}
    .form-grid{grid-template-columns:1fr;}
    th:nth-child(5),td:nth-child(5),
    th:nth-child(6),td:nth-child(6){display:none;}
  }
</style>
</head>
<body>

<header>
  <div class="logo-area">
    <svg width="36" height="36" viewBox="0 0 58 58" fill="none">
      <path d="M29 6L5 26V52H22V36H36V52H53V26L29 6Z" fill="#C8960C"/>
      <path d="M22 36H36V52H22V36Z" fill="#8A6010"/>
      <path d="M29 6L5 26H10L29 11L48 26H53L29 6Z" fill="#8A6010"/>
      <rect x="24" y="20" width="10" height="10" rx="1" fill="#0F0A04" opacity="0.5"/>
    </svg>
    <div class="logo-text">
      <span>REX</span>
      <span>Realtyco · Property Database</span>
    </div>
  </div>
  <div class="header-right">
    <div class="stat-pill">Total <strong id="header-total">—</strong></div>
    <div class="stat-pill">Available <strong id="header-available">—</strong></div>
    <div class="sync-status">
      <div class="sync-dot" id="sync-dot"></div>
      <span id="sync-label">Live</span>
    </div>
  </div>
</header>

<main>
  <div class="top-bar">
    <div class="page-title">Property <span>Listings</span></div>
    <button class="btn-add" onclick="openAddModal()">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M7 1V13M1 7H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      Add Listing
    </button>
  </div>

  <div class="stats-grid">
    <div class="stat-card"><div class="stat-card-label">Total Listings</div><div class="stat-card-value" id="stat-total">—</div></div>
    <div class="stat-card"><div class="stat-card-label">For Sale</div><div class="stat-card-value" id="stat-sale">—</div></div>
    <div class="stat-card"><div class="stat-card-label">For Rent</div><div class="stat-card-value" id="stat-rent">—</div></div>
    <div class="stat-card"><div class="stat-card-label">Sold / Under Offer</div><div class="stat-card-value" id="stat-closed">—</div></div>
  </div>

  <div class="filters">
    <input class="search-box" type="text" placeholder="Search by name, location, agent..." id="search-input" oninput="renderTable()">
    <button class="filter-btn active" onclick="setFilter('all',this)">All</button>
    <button class="filter-btn" onclick="setFilter('For Sale',this)">For Sale</button>
    <button class="filter-btn" onclick="setFilter('For Rent',this)">For Rent</button>
    <button class="filter-btn" onclick="setFilter('Sold',this)">Sold</button>
    <button class="filter-btn" onclick="setFilter('Under Offer',this)">Under Offer</button>
    <select class="filter-select" id="type-filter" onchange="renderTable()">
      <option value="all">All Types</option>
      <option value="Residential">Residential</option>
      <option value="Commercial">Commercial</option>
      <option value="Land">Land</option>
      <option value="Short Let">Short Let</option>
    </select>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Property</th>
          <th>Type</th>
          <th>Price</th>
          <th>Status</th>
          <th>Agent</th>
          <th>Date Listed</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="listings-tbody">
        <tr class="loading-row"><td colspan="7"><span class="loader"></span>Loading listings from Google Sheets...</td></tr>
      </tbody>
    </table>
  </div>
</main>

<!-- ADD/EDIT MODAL -->
<div class="modal-overlay" id="add-modal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="modal-title">Add New Listing</div>
      <button class="modal-close" onclick="closeModal('add-modal')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-grid">
        <div class="form-group full">
          <label>Property Name</label>
          <input type="text" id="f-name" placeholder="e.g. Ugomma Duplex, Awka">
        </div>
        <div class="form-group full">
          <label>Location / Address</label>
          <input type="text" id="f-location" placeholder="e.g. Jahi, Abuja">
        </div>
        <div class="form-group">
          <label>Property Type</label>
          <select id="f-type">
            <option value="Residential">Residential</option>
            <option value="Commercial">Commercial</option>
            <option value="Land">Land</option>
            <option value="Short Let">Short Let</option>
          </select>
        </div>
        <div class="form-group">
          <label>Status</label>
          <select id="f-status">
            <option value="For Sale">For Sale</option>
            <option value="For Rent">For Rent</option>
            <option value="Under Offer">Under Offer</option>
            <option value="Sold">Sold</option>
          </select>
        </div>
        <div class="form-group">
          <label>Price (₦)</label>
          <input type="text" id="f-price" placeholder="e.g. 85,000,000">
        </div>
        <div class="form-group">
          <label>Price Period</label>
          <select id="f-period">
            <option value="Outright">Outright</option>
            <option value="Per Annum">Per Annum</option>
            <option value="Per Month">Per Month</option>
            <option value="Per Night">Per Night</option>
          </select>
        </div>
        <div class="form-group">
          <label>Bedrooms</label>
          <input type="text" id="f-beds" placeholder="e.g. 4 Bedrooms">
        </div>
        <div class="form-group">
          <label>Size (sqm)</label>
          <input type="text" id="f-size" placeholder="e.g. 400sqm">
        </div>
        <div class="form-group">
          <label>Agent Name</label>
          <input type="text" id="f-agent" placeholder="e.g. Chisom Okafor">
        </div>
        <div class="form-group">
          <label>Agent Phone</label>
          <input type="text" id="f-phone" placeholder="e.g. 08012345678">
        </div>
        <div class="form-group full">
          <label>Notes</label>
          <textarea id="f-notes" placeholder="Any additional notes..."></textarea>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('add-modal')">Cancel</button>
      <button class="btn-save" id="btn-save" onclick="saveListing()">Save Listing</button>
    </div>
  </div>
</div>

<!-- VIEW MODAL -->
<div class="modal-overlay" id="view-modal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="view-title">Property Details</div>
      <button class="modal-close" onclick="closeModal('view-modal')">✕</button>
    </div>
    <div class="modal-body" id="view-body"></div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('view-modal')">Close</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  const API = "https://script.google.com/macros/s/AKfycbwfZGPV6k3nBENtH9vvs87t8fNMs9_H7NfleaZS6X3Cz22VTF8EyD_4CY_sKmywKSYF/exec";

  let listings = [];
  let editingId = null;
  let currentFilter = 'all';

  // ── TOAST ──────────────────────────────────────
  function showToast(msg, type = 'success') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = `toast ${type} show`;
    setTimeout(() => t.className = 'toast', 3000);
  }

  // ── SYNC INDICATOR ─────────────────────────────
  function setSyncStatus(state) {
    const dot = document.getElementById('sync-dot');
    const label = document.getElementById('sync-label');
    dot.className = 'sync-dot' + (state === 'syncing' ? ' syncing' : state === 'error' ? ' error' : '');
    label.textContent = state === 'syncing' ? 'Syncing...' : state === 'error' ? 'Offline' : 'Live';
  }

  // ── FETCH FROM SHEETS ──────────────────────────
  async function loadListings() {
    setSyncStatus('syncing');
    try {
      const res = await fetch(API);
      const json = await res.json();
      if (json.success) {
        listings = json.data.filter(r => r.ID).map(r => ({
          id: r.ID,
          name: r.Name,
          location: r.Location,
          type: r.Type,
          status: r.Status,
          price: r.Price,
          period: r.Period,
          beds: r.Beds,
          size: r.Size,
          agent: r.Agent,
          phone: r.Phone,
          notes: r.Notes,
          date: r.Date,
        }));
        setSyncStatus('live');
        renderTable();
      } else {
        throw new Error('Sheet error');
      }
    } catch (err) {
      setSyncStatus('error');
      document.getElementById('listings-tbody').innerHTML =
        `<tr><td colspan="7" class="no-results">Could not load listings — check your connection</td></tr>`;
      showToast('Could not connect to Google Sheets', 'error');
    }
  }

  // ── CALL APPS SCRIPT ───────────────────────────
  async function callAPI(payload) {
    setSyncStatus('syncing');
    const res = await fetch(API, {
      method: 'POST',
      body: JSON.stringify(payload),
    });
    const json = await res.json();
    setSyncStatus(json.success ? 'live' : 'error');
    return json;
  }

  // ── HELPERS ────────────────────────────────────
  function formatDate(d) {
    if (!d) return '—';
    const dt = new Date(d);
    return isNaN(dt) ? d : dt.toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' });
  }

  function statusBadge(s) {
    const map = {'For Sale':'sale','For Rent':'rent','Sold':'sold','Under Offer':'offer'};
    return `<span class="badge badge-${map[s]||'sale'}">${s}</span>`;
  }

  function typeBadge(t) {
    const map = {'Residential':'residential','Commercial':'commercial','Land':'land','Short Let':'shortlet'};
    return `<span class="type-badge type-${map[t]||'residential'}">${t}</span>`;
  }

  function updateStats() {
    const total = listings.length;
    document.getElementById('stat-total').textContent = total;
    document.getElementById('stat-sale').textContent = listings.filter(l=>l.status==='For Sale').length;
    document.getElementById('stat-rent').textContent = listings.filter(l=>l.status==='For Rent').length;
    document.getElementById('stat-closed').textContent = listings.filter(l=>l.status==='Sold'||l.status==='Under Offer').length;
    document.getElementById('header-total').textContent = total;
    document.getElementById('header-available').textContent = listings.filter(l=>l.status==='For Sale'||l.status==='For Rent').length;
  }

  function getFiltered() {
    const search = document.getElementById('search-input').value.toLowerCase();
    const typeFilter = document.getElementById('type-filter').value;
    return listings.filter(l => {
      const matchStatus = currentFilter === 'all' || l.status === currentFilter;
      const matchType = typeFilter === 'all' || l.type === typeFilter;
      const matchSearch = !search ||
        (l.name||'').toLowerCase().includes(search) ||
        (l.location||'').toLowerCase().includes(search) ||
        (l.agent||'').toLowerCase().includes(search);
      return matchStatus && matchType && matchSearch;
    });
  }

  function renderTable() {
    updateStats();
    const filtered = getFiltered();
    const tbody = document.getElementById('listings-tbody');
    if (!filtered.length) {
      tbody.innerHTML = `<tr><td colspan="7" class="no-results">No listings found</td></tr>`;
      return;
    }
    tbody.innerHTML = filtered.map((l,i) => `
      <tr style="animation-delay:${i*0.04}s">
        <td>
          <div class="prop-name">${l.name||'—'}</div>
          <div class="prop-location">📍 ${l.location||'—'}</div>
        </td>
        <td>${typeBadge(l.type)}</td>
        <td>
          <div class="price">₦${l.price||'—'}</div>
          <div class="price-sub">${l.period||''}</div>
        </td>
        <td>${statusBadge(l.status)}</td>
        <td>
          <div class="agent-name">${l.agent||'—'}</div>
          <div class="date">${l.phone||''}</div>
        </td>
        <td><div class="date">${formatDate(l.date)}</div></td>
        <td>
          <div class="actions">
            <button class="btn-action" onclick="viewListing('${l.id}')">View</button>
            <button class="btn-action" onclick="editListing('${l.id}')">Edit</button>
            <button class="btn-action btn-delete" onclick="deleteListing('${l.id}')">Del</button>
          </div>
        </td>
      </tr>
    `).join('');
  }

  function setFilter(f, btn) {
    currentFilter = f;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderTable();
  }

  // ── ADD / EDIT MODAL ───────────────────────────
  function openAddModal() {
    editingId = null;
    document.getElementById('modal-title').textContent = 'Add New Listing';
    ['name','location','price','beds','size','agent','phone','notes'].forEach(f => {
      document.getElementById('f-'+f).value = '';
    });
    document.getElementById('f-type').value = 'Residential';
    document.getElementById('f-status').value = 'For Sale';
    document.getElementById('f-period').value = 'Outright';
    document.getElementById('add-modal').classList.add('open');
  }

  function editListing(id) {
    const l = listings.find(x => String(x.id) === String(id));
    if (!l) return;
    editingId = id;
    document.getElementById('modal-title').textContent = 'Edit Listing';
    document.getElementById('f-name').value = l.name||'';
    document.getElementById('f-location').value = l.location||'';
    document.getElementById('f-type').value = l.type||'Residential';
    document.getElementById('f-status').value = l.status||'For Sale';
    document.getElementById('f-price').value = l.price||'';
    document.getElementById('f-period').value = l.period||'Outright';
    document.getElementById('f-beds').value = l.beds||'';
    document.getElementById('f-size').value = l.size||'';
    document.getElementById('f-agent').value = l.agent||'';
    document.getElementById('f-phone').value = l.phone||'';
    document.getElementById('f-notes').value = l.notes||'';
    document.getElementById('add-modal').classList.add('open');
  }

  async function saveListing() {
    const name = document.getElementById('f-name').value.trim();
    const location = document.getElementById('f-location').value.trim();
    if (!name || !location) { showToast('Name and Location are required', 'error'); return; }

    const btn = document.getElementById('btn-save');
    btn.disabled = true;
    btn.textContent = 'Saving...';

    const data = {
      id: editingId || Date.now().toString(),
      name,
      location,
      type: document.getElementById('f-type').value,
      status: document.getElementById('f-status').value,
      price: document.getElementById('f-price').value.trim(),
      period: document.getElementById('f-period').value,
      beds: document.getElementById('f-beds').value.trim(),
      size: document.getElementById('f-size').value.trim(),
      agent: document.getElementById('f-agent').value.trim(),
      phone: document.getElementById('f-phone').value.trim(),
      notes: document.getElementById('f-notes').value.trim(),
      date: new Date().toISOString().split('T')[0],
      action: editingId ? 'edit' : 'add',
    };

    try {
      const res = await callAPI(data);
      if (res.success) {
        showToast(editingId ? 'Listing updated ✓' : 'Listing added ✓', 'success');
        closeModal('add-modal');
        await loadListings();
      } else {
        showToast('Error saving listing', 'error');
      }
    } catch {
      showToast('Connection error — try again', 'error');
    }

    btn.disabled = false;
    btn.textContent = 'Save Listing';
  }

  async function deleteListing(id) {
    if (!confirm('Remove this listing from the database?')) return;
    try {
      const res = await callAPI({ action: 'delete', id });
      if (res.success) {
        showToast('Listing removed', 'success');
        await loadListings();
      } else {
        showToast('Could not delete listing', 'error');
      }
    } catch {
      showToast('Connection error', 'error');
    }
  }

  function viewListing(id) {
    const l = listings.find(x => String(x.id) === String(id));
    if (!l) return;
    document.getElementById('view-title').textContent = l.name;
    document.getElementById('view-body').innerHTML = `
      <div class="detail-row"><span class="detail-label">Location</span><span class="detail-value">${l.location||'—'}</span></div>
      <div class="detail-row"><span class="detail-label">Type</span><span class="detail-value">${l.type||'—'}</span></div>
      <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value">${l.status||'—'}</span></div>
      <div class="detail-row"><span class="detail-label">Price</span><span class="detail-value" style="color:var(--gold);font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:600;">₦${l.price||'—'} <span style="font-size:11px;color:var(--text-muted)">${l.period||''}</span></span></div>
      <div class="detail-row"><span class="detail-label">Bedrooms</span><span class="detail-value">${l.beds||'—'}</span></div>
      <div class="detail-row"><span class="detail-label">Size</span><span class="detail-value">${l.size||'—'}</span></div>
      <div class="detail-row"><span class="detail-label">Agent</span><span class="detail-value">${l.agent||'—'}</span></div>
      <div class="detail-row"><span class="detail-label">Phone</span><span class="detail-value">${l.phone||'—'}</span></div>
      <div class="detail-row"><span class="detail-label">Date Listed</span><span class="detail-value">${formatDate(l.date)}</span></div>
      ${l.notes?`<div class="detail-row"><span class="detail-label">Notes</span><span class="detail-value" style="max-width:60%;text-align:right;color:var(--text-dim)">${l.notes}</span></div>`:''}
    `;
    document.getElementById('view-modal').classList.add('open');
  }

  function closeModal(id) {
    document.getElementById(id).classList.remove('open');
  }

  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', function(e) {
      if (e.target === this) this.classList.remove('open');
    });
  });

  // Init
  loadListings();
</script>
</body>
</html>
